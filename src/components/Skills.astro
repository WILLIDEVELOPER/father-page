---
const skills = [
	{ name: "Soldadura TIG", level: 95 },
	{ name: "Soldadura MIG/MAG", level: 95 },
	{ name: "Soldadura de Arco", level: 90 },
	{ name: "Acero Inoxidable", level: 95 },
	{ name: "Aluminio", level: 85 },
	{ name: "Pulido y Acabados", level: 90 },
	{ name: "Lectura de Planos", level: 85 },
	{ name: "Fabricación Metálica", level: 95 },
];

const materials = [
	{ name: "Acero Inoxidable", icon: "◆" },
	{ name: "Acero al Carbono", icon: "◆" },
	{ name: "Aluminio", icon: "◆" },
	{ name: "Hierro Forjado", icon: "◆" },
	{ name: "Acero Galvanizado", icon: "◆" },
	{ name: "Madera + Metal", icon: "◆" },
	{ name: "Cobre y Bronce", icon: "◆" },
	{ name: "Acero Estructural", icon: "◆" },
];
---

<section class="skills" id="habilidades">
	<div class="container">
		<div class="section-header">
			<span class="section-label">Habilidades</span>
			<h2 class="section-title">Expertise <span class="accent-text">Técnico</span></h2>
			<p class="section-subtitle">
				Dominio completo de técnicas de soldadura y fabricación metálica 
				perfeccionadas durante más de 15 años.
			</p>
		</div>

		<div class="skills-grid">
			<div class="skills-bars">
				<h3 class="skills-section-title">Competencias Técnicas</h3>
				{skills.map((skill) => (
					<div class="skill-item">
						<div class="skill-header">
							<span class="skill-name">{skill.name}</span>
							<span class="skill-percent">{skill.level}%</span>
						</div>
						<div class="skill-bar">
							<div class="skill-fill" style={`--skill-width: ${skill.level}%`}></div>
						</div>
					</div>
				))}
			</div>

			<div class="skills-materials">
				<h3 class="skills-section-title">Materiales que Domino</h3>
				<div class="materials-grid">
					{materials.map((material) => (
						<div class="material-item">
							<span class="material-icon">{material.icon}</span>
							<span class="material-name">{material.name}</span>
						</div>
					))}
				</div>

				<div class="process-card">
					<h4 class="process-title">Mi Proceso de Trabajo</h4>
					<div class="process-steps">
						<div class="process-step">
							<div class="step-number">01</div>
							<div>
								<strong>Consulta</strong>
								<p>Evaluación del proyecto y necesidades</p>
							</div>
						</div>
						<div class="process-step">
							<div class="step-number">02</div>
							<div>
								<strong>Diseño</strong>
								<p>Planos, medidas y presupuesto</p>
							</div>
						</div>
						<div class="process-step">
							<div class="step-number">03</div>
							<div>
								<strong>Fabricación</strong>
								<p>Corte, soldadura y ensamblaje</p>
							</div>
						</div>
						<div class="process-step">
							<div class="step-number">04</div>
							<div>
								<strong>Entrega</strong>
								<p>Acabado, pulido e instalación</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.skills {
		padding: var(--section-padding);
		background: var(--color-bg-primary);
		position: relative;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
	}

	.skills-section-title {
		font-size: 1.2rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid var(--color-border);
	}

	/* Skill Bars */
	.skill-item {
		margin-bottom: 1.2rem;
	}

	.skill-header {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}

	.skill-name {
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--color-text-secondary);
	}

	.skill-percent {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--color-accent);
		font-family: var(--font-heading);
		letter-spacing: 1px;
	}

	.skill-bar {
		width: 100%;
		height: 6px;
		background: var(--color-bg-tertiary);
		border-radius: 3px;
		overflow: hidden;
	}

	.skill-fill {
		height: 100%;
		background: linear-gradient(90deg, var(--color-accent-dark), var(--color-accent));
		border-radius: 3px;
		width: var(--skill-width);
		animation: fillBar 1.5s ease forwards;
		transform-origin: left;
	}

	@keyframes fillBar {
		from { width: 0; }
		to { width: var(--skill-width); }
	}

	/* Materials Grid */
	.materials-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.8rem;
		margin-bottom: 2rem;
	}

	.material-item {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.7rem 1rem;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		font-size: 0.85rem;
		color: var(--color-text-secondary);
		transition: all var(--transition-normal);
	}

	.material-item:hover {
		border-color: var(--color-accent);
		color: var(--color-text-primary);
	}

	.material-icon {
		color: var(--color-accent);
		font-size: 0.7rem;
	}

	.material-name {
		font-weight: 500;
	}

	/* Process Card */
	.process-card {
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 10px;
		padding: 1.5rem;
	}

	.process-title {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 1.2rem;
		color: var(--color-accent);
	}

	.process-steps {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.process-step {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
	}

	.step-number {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		color: var(--color-accent);
		opacity: 0.5;
		line-height: 1;
		min-width: 30px;
	}

	.process-step strong {
		display: block;
		font-size: 0.9rem;
		margin-bottom: 0.15rem;
	}

	.process-step p {
		font-size: 0.78rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 768px) {
		.skills-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}
</style>
