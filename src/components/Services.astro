---
const services = [
	{
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
		title: "Soldadura Profesional",
		description: "Soldadura TIG, MIG, arco eléctrico y oxiacetilénica. Trabajos en acero inoxidable, aluminio, hierro y acero al carbono con acabados impecables.",
	},
	{
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>`,
		title: "Tanques Industriales",
		description: "Fabricación de tanques para almacenamiento de leche fresca, agua, químicos y uso alimentario. Diseño a medida con certificación de calidad.",
	},
	{
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-6h6v6"/></svg>`,
		title: "Estructuras Metálicas",
		description: "Diseño y construcción de estructuras, techos, portones, rejas, escaleras y barandas. Proyectos residenciales e industriales.",
	},
	{
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="22" height="18" rx="2"/><line x1="1" y1="9" x2="23" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`,
		title: "Mobiliario en Metal",
		description: "Mesas, sillas, estantes, repisas y muebles personalizados en acero, aluminio y combinaciones con madera. Diseño moderno e industrial.",
	},
	{
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
		title: "Maquinaria a Medida",
		description: "Diseño y fabricación de maquinaria especializada, tolvas, transportadores, equipos industriales y piezas mecánicas de precisión.",
	},
	{
		icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3h7a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-7m0-18H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7m0-18v18"/><path d="M16 12h-4"/><path d="M16 8h-4"/><path d="M16 16h-4"/></svg>`,
		title: "Pulido y Acabados",
		description: "Pulido espejo, satinado, cepillado y acabados especiales en todo tipo de metales. Restauración y renovación de piezas existentes.",
	},
];
---

<section class="services" id="servicios">
	<div class="container">
		<div class="section-header">
			<span class="section-label">Servicios</span>
			<h2 class="section-title">Lo que <span class="accent-text">Ofrecemos</span></h2>
			<p class="section-subtitle">
				Soluciones integrales en metalurgia y fabricación metálica para proyectos 
				residenciales, comerciales e industriales.
			</p>
		</div>

		<div class="services-grid">
			{services.map((service, idx) => (
				<div class="service-card" style={`animation-delay: ${idx * 0.1}s`}>
					<div class="service-icon" set:html={service.icon} />
					<h3 class="service-title">{service.title}</h3>
					<p class="service-description">{service.description}</p>
					<div class="service-line"></div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.services {
		padding: var(--section-padding);
		background: var(--color-bg-primary);
		position: relative;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.service-card {
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 2rem;
		transition: all var(--transition-normal);
		position: relative;
		overflow: hidden;
	}

	.service-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--color-accent);
		transform: scaleX(0);
		transition: transform var(--transition-normal);
		transform-origin: left;
	}

	.service-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-5px);
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(232, 130, 12, 0.05);
	}

	.service-card:hover::before {
		transform: scaleX(1);
	}

	.service-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(232, 130, 12, 0.1);
		border-radius: 12px;
		margin-bottom: 1.2rem;
		color: var(--color-accent);
		transition: all var(--transition-normal);
	}

	.service-icon :global(svg) {
		width: 24px;
		height: 24px;
	}

	.service-card:hover .service-icon {
		background: var(--color-accent);
		color: #000;
		transform: scale(1.05);
	}

	.service-title {
		font-size: 1.15rem;
		font-weight: 700;
		margin-bottom: 0.6rem;
		letter-spacing: 0.3px;
	}

	.service-description {
		font-size: 0.88rem;
		color: var(--color-text-secondary);
		line-height: 1.7;
	}

	.service-line {
		width: 30px;
		height: 2px;
		background: var(--color-border-light);
		margin-top: 1.2rem;
		transition: all var(--transition-normal);
	}

	.service-card:hover .service-line {
		width: 50px;
		background: var(--color-accent);
	}

	@media (max-width: 1024px) {
		.services-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
