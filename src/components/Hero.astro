---

<section class="hero" id="inicio">
	<div class="hero-bg">
		<div class="hero-overlay"></div>
		<div class="hero-sparks">
			<div class="spark spark-1"></div>
			<div class="spark spark-2"></div>
			<div class="spark spark-3"></div>
			<div class="spark spark-4"></div>
			<div class="spark spark-5"></div>
		</div>
	</div>
	
	<div class="container hero-content">
		<div class="hero-badge">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
			</svg>
			Más de 15 años de experiencia
		</div>
		
		<h1 class="hero-title">
			Soldadura &<br/>
			<span class="accent-text">Fabricación Metálica</span><br/>
			de Alto Nivel
		</h1>
		
		<p class="hero-description">
			Especialista en soldadura, fabricación y diseño de estructuras metálicas, 
			tanques industriales, maquinaria, mobiliario en acero inoxidable, aluminio 
			y todo tipo de trabajos en metal. Calidad, precisión y acabados profesionales 
			en cada proyecto.
		</p>
		
		<div class="hero-actions">
			<a href="#proyectos" class="btn btn-primary">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
					<rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
				</svg>
				Ver Proyectos
			</a>
			<a href="#contacto" class="btn btn-outline">
				Solicitar Cotización
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
				</svg>
			</a>
		</div>

		<div class="hero-stats">
			<div class="stat">
				<span class="stat-number">15+</span>
				<span class="stat-label">Años de<br/>Experiencia</span>
			</div>
			<div class="stat-divider"></div>
			<div class="stat">
				<span class="stat-number">200+</span>
				<span class="stat-label">Proyectos<br/>Completados</span>
			</div>
			<div class="stat-divider"></div>
			<div class="stat">
				<span class="stat-number">100%</span>
				<span class="stat-label">Compromiso<br/>y Calidad</span>
			</div>
		</div>
	</div>

	<div class="hero-scroll">
		<a href="#sobre-mi" class="scroll-indicator">
			<span class="scroll-text">Explorar</span>
			<div class="scroll-line"></div>
		</a>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background: 
			radial-gradient(ellipse at 20% 50%, rgba(232, 130, 12, 0.08) 0%, transparent 60%),
			radial-gradient(ellipse at 80% 20%, rgba(232, 130, 12, 0.05) 0%, transparent 50%),
			linear-gradient(180deg, var(--color-bg-primary) 0%, var(--color-bg-secondary) 100%);
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background-image: 
			repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(255,255,255,0.02) 50px),
			repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(255,255,255,0.02) 50px);
		background-size: 50px 50px;
	}

	/* Animated sparks */
	.spark {
		position: absolute;
		width: 3px;
		height: 3px;
		background: var(--color-accent);
		border-radius: 50%;
		box-shadow: 0 0 6px var(--color-accent), 0 0 12px var(--color-accent);
	}

	.spark-1 { top: 20%; left: 15%; animation: sparkle 3s ease-in-out infinite; }
	.spark-2 { top: 60%; left: 80%; animation: sparkle 2.5s ease-in-out infinite 0.5s; }
	.spark-3 { top: 35%; left: 70%; animation: sparkle 4s ease-in-out infinite 1s; }
	.spark-4 { top: 75%; left: 25%; animation: sparkle 3.5s ease-in-out infinite 1.5s; }
	.spark-5 { top: 45%; left: 55%; animation: sparkle 2.8s ease-in-out infinite 0.8s; }

	@keyframes sparkle {
		0%, 100% { opacity: 0; transform: scale(0); }
		50% { opacity: 1; transform: scale(1); }
	}

	.hero-content {
		position: relative;
		z-index: 2;
		padding-top: 8rem;
		padding-bottom: 4rem;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: rgba(232, 130, 12, 0.1);
		border: 1px solid rgba(232, 130, 12, 0.3);
		border-radius: 100px;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-accent);
		margin-bottom: 2rem;
		animation: fadeInUp 0.7s ease forwards;
	}

	.hero-title {
		font-family: var(--font-heading);
		font-size: clamp(3rem, 8vw, 6rem);
		line-height: 1.05;
		letter-spacing: 3px;
		margin-bottom: 1.5rem;
		animation: fadeInUp 0.7s ease 0.15s forwards;
		opacity: 0;
	}

	.hero-description {
		font-size: 1.1rem;
		color: var(--color-text-secondary);
		max-width: 600px;
		line-height: 1.8;
		margin-bottom: 2.5rem;
		animation: fadeInUp 0.7s ease 0.3s forwards;
		opacity: 0;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 4rem;
		animation: fadeInUp 0.7s ease 0.45s forwards;
		opacity: 0;
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 2rem;
		animation: fadeInUp 0.7s ease 0.6s forwards;
		opacity: 0;
	}

	.stat {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.stat-number {
		font-family: var(--font-heading);
		font-size: 2.5rem;
		color: var(--color-accent);
		letter-spacing: 2px;
		line-height: 1;
	}

	.stat-label {
		font-size: 0.75rem;
		color: var(--color-text-secondary);
		text-transform: uppercase;
		letter-spacing: 1px;
		line-height: 1.4;
	}

	.stat-divider {
		width: 1px;
		height: 40px;
		background: var(--color-border-light);
	}

	/* Scroll indicator */
	.hero-scroll {
		position: absolute;
		bottom: 2rem;
		right: 2rem;
		z-index: 2;
	}

	.scroll-indicator {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-text-muted);
		transition: color var(--transition-normal);
	}

	.scroll-indicator:hover {
		color: var(--color-accent);
	}

	.scroll-text {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 2px;
		writing-mode: vertical-rl;
	}

	.scroll-line {
		width: 1px;
		height: 60px;
		background: currentColor;
		animation: scrollPulse 2s ease-in-out infinite;
	}

	@keyframes scrollPulse {
		0%, 100% { opacity: 0.3; transform: scaleY(0.5); transform-origin: top; }
		50% { opacity: 1; transform: scaleY(1); }
	}

	@media (max-width: 768px) {
		.hero-content {
			padding-top: 7rem;
		}

		.hero-stats {
			flex-direction: column;
			align-items: flex-start;
			gap: 1.5rem;
		}

		.stat-divider {
			width: 40px;
			height: 1px;
		}

		.hero-scroll {
			display: none;
		}
	}
</style>
