---

<section class="about" id="sobre-mi">
	<div class="container">
		<div class="about-grid">
			<div class="about-visual">
				<div class="about-image-frame">
					<div class="about-image-placeholder">
						<svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect width="200" height="200" fill="#1a1a1a"/>
							<!-- Welder silhouette -->
							<circle cx="100" cy="65" r="25" fill="#2a2a2a"/>
							<path d="M60 130 C60 100, 140 100, 140 130 L140 200 L60 200 Z" fill="#2a2a2a"/>
							<!-- Welding arc -->
							<circle cx="145" cy="110" r="8" fill="#2563eb" opacity="0.6"/>
							<circle cx="145" cy="110" r="15" fill="#2563eb" opacity="0.2"/>
							<circle cx="145" cy="110" r="22" fill="#2563eb" opacity="0.1"/>
							<!-- Sparks -->
							<line x1="145" y1="110" x2="160" y2="95" stroke="#3b82f6" stroke-width="1.5" opacity="0.7"/>
							<line x1="145" y1="110" x2="165" y2="105" stroke="#3b82f6" stroke-width="1.5" opacity="0.5"/>
							<line x1="145" y1="110" x2="155" y2="88" stroke="#3b82f6" stroke-width="1" opacity="0.6"/>
							<line x1="145" y1="110" x2="168" y2="115" stroke="#3b82f6" stroke-width="1" opacity="0.4"/>
							<circle cx="160" cy="95" r="2" fill="#3b82f6" opacity="0.8"/>
							<circle cx="165" cy="105" r="1.5" fill="#3b82f6" opacity="0.6"/>
							<circle cx="155" cy="88" r="1.5" fill="#3b82f6" opacity="0.7"/>
						</svg>
						<div class="photo-hint">Tu foto aquí</div>
					</div>
					<div class="about-accent-border"></div>
				</div>
				<div class="about-experience-badge">
					<span class="badge-number">15+</span>
					<span class="badge-text">Años de<br/>experiencia</span>
				</div>
			</div>

			<div class="about-content">
				<div class="section-header" style="text-align: left; margin-bottom: 2rem;">
					<span class="section-label">Sobre Mí</span>
					<h2 class="section-title">Pasión por el Metal,<br/><span class="accent-text">Precisión</span> en cada Detalle</h2>
				</div>

				<p class="about-text">
					Con más de <strong>15 años de experiencia</strong> en el sector metalúrgico, me he 
					dedicado a perfeccionar cada aspecto de mi oficio. Desde soldadura TIG, MIG y de arco, 
					hasta el pulido, armado y acabado final de cada pieza, mi compromiso es entregar 
					trabajo de la más alta calidad.
				</p>

				<p class="about-text">
					He trabajado en una amplia variedad de proyectos: desde <strong>tanques industriales 
					para almacenamiento de leche fresca</strong>, maquinaria especializada, estructuras 
					metálicas, hasta mobiliario personalizado en acero, aluminio y madera. Cada proyecto 
					es una oportunidad de demostrar excelencia.
				</p>

				<div class="about-features">
					<div class="feature">
						<div class="feature-icon">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
								<polyline points="22 4 12 14.01 9 11.01"/>
							</svg>
						</div>
						<div>
							<h4 class="feature-title">Calidad Garantizada</h4>
							<p class="feature-desc">Acabados de primer nivel en cada trabajo</p>
						</div>
					</div>
					<div class="feature">
						<div class="feature-icon">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<circle cx="12" cy="12" r="10"/>
								<polyline points="12 6 12 12 16 14"/>
							</svg>
						</div>
						<div>
							<h4 class="feature-title">Entregas Puntuales</h4>
							<p class="feature-desc">Compromiso con los tiempos acordados</p>
						</div>
					</div>
					<div class="feature">
						<div class="feature-icon">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
							</svg>
						</div>
						<div>
							<h4 class="feature-title">Experiencia Comprobada</h4>
							<p class="feature-desc">Más de 200 proyectos exitosos</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.about {
		padding: var(--section-padding);
		background: var(--color-bg-secondary);
		position: relative;
	}

	.about::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-border-light), transparent);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 5rem;
		align-items: center;
	}

	.about-visual {
		position: relative;
	}

	.about-image-frame {
		position: relative;
		border-radius: 8px;
		overflow: hidden;
	}

	.about-image-placeholder {
		aspect-ratio: 1;
		background: var(--color-bg-tertiary);
		border-radius: 8px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		border: 2px dashed var(--color-border-light);
		position: relative;
		overflow: hidden;
	}

	.about-image-placeholder svg {
		width: 100%;
		height: 100%;
		position: absolute;
		top: 0;
		left: 0;
	}

	.photo-hint {
		position: relative;
		z-index: 2;
		background: rgba(0,0,0,0.7);
		padding: 0.5rem 1.2rem;
		border-radius: 4px;
		font-size: 0.85rem;
		color: var(--color-text-secondary);
		border: 1px solid var(--color-border);
	}

	.about-accent-border {
		position: absolute;
		bottom: -8px;
		right: -8px;
		width: 60%;
		height: 60%;
		border: 2px solid var(--color-accent);
		border-radius: 8px;
		z-index: -1;
		opacity: 0.3;
	}

	.about-experience-badge {
		position: absolute;
		bottom: -20px;
		right: -20px;
		background: var(--color-accent);
		color: #000;
		padding: 1.2rem 1.5rem;
		border-radius: 8px;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		animation: pulseGlow 3s ease-in-out infinite;
	}

	.badge-number {
		font-family: var(--font-heading);
		font-size: 2.5rem;
		line-height: 1;
		letter-spacing: 1px;
	}

	.badge-text {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1px;
		line-height: 1.3;
	}

	.about-content {
		/* No extra styling needed */
	}

	.about-text {
		color: var(--color-text-secondary);
		line-height: 1.8;
		margin-bottom: 1.2rem;
		font-size: 1rem;
	}

	.about-text strong {
		color: var(--color-text-primary);
		font-weight: 600;
	}

	.about-features {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		margin-top: 2rem;
	}

	.feature {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem 1.2rem;
		background: var(--color-bg-card);
		border-radius: 8px;
		border: 1px solid var(--color-border);
		transition: all var(--transition-normal);
	}

	.feature:hover {
		border-color: var(--color-accent);
		transform: translateX(5px);
	}

	.feature-icon {
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(37, 99, 235, 0.1);
		border-radius: 8px;
		color: var(--color-accent);
	}

	.feature-icon svg {
		width: 20px;
		height: 20px;
	}

	.feature-title {
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 0.15rem;
	}

	.feature-desc {
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 768px) {
		.about-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.about-visual {
			max-width: 350px;
			margin: 0 auto;
		}

		.about-experience-badge {
			bottom: -10px;
			right: -10px;
		}
	}
</style>
